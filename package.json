{
  "name": "dependecy-risk-analyzer",
  "displayName": "Dependency Risk Analyzer",
  "description": "Analyze dependency risk, usage and project health in VS Code",
  "version": "0.0.1",
  "publisher": "ankur-dev",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:dependencyListView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dependency-risk",
          "title": "Dependencies",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "dependency-risk": [
        {
          "id": "dependencyListView",
          "name": "Dependency Risk Analyzer",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "dependecy-risk-analyzer.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "repository": {
  "type": "git",
  "url": "https://github.com/ankurtk/dependency-risk-analyzer"
},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
